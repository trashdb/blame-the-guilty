<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BlameTheGuilty.Desktop.MainWindow"
        Title="Blame the Guilty"
        Width="450" Height="300"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Blame the Guilty - CI/CD Punishment System"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,15"
                   HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <TextBlock Text="Status: " VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText" Text="Not authenticated" Foreground="Gray" VerticalAlignment="Center"/>
        </StackPanel>

        <Button x:Name="LoginButton" Grid.Row="2"
                Content="Login con GitHub"
                Padding="20,10"
                HorizontalAlignment="Center"
                FontSize="14"
                Click="LoginButton_Click"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <TextBlock Text="User: " VerticalAlignment="Center"/>
            <TextBlock x:Name="UserText" Text="-" Foreground="Gray" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
            <TextBlock Text="Connection: " VerticalAlignment="Center"/>
            <TextBlock x:Name="ConnectionText" Text="Disconnected" Foreground="Red" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
